# =========================================================================
# E-Sevai SaaS Frontend Environment Variables Template
# Copy this file to '.env' (for local) or '.env.production' / '.env.staging'
# =========================================================================

# Application Config
VITE_APP_NAME="E-Sevai SaaS Platform"
VITE_APP_VERSION="1.0.0"

# Target Environment Profile (development, staging, production)
VITE_ENVIRONMENT="development"

# Backend Endpoint Base URL (Prefix namespace for apiClient.js)
# Local Dev Default: http://localhost:5000/api/v1
# Staging Domain:    https://staging-api.esevaisaas.gov.in/api/v1
# Production Domain: https://api.esevaisaas.gov.in/api/v1
VITE_API_BASE_URL="http://localhost:5000/api/v1"

# Document Storage CDN Endpoint Base URL
# Points to Supabase storage public buckets or S3 CDN mirrors
VITE_STORAGE_URL="http://localhost:5000/api/v1/documents"

# Session Settings
# JWT storage key name inside browser localStorage
VITE_STORAGE_TOKEN_KEY="e_sevai_auth_token"

# Request Timeout Duration (In milliseconds)
VITE_API_TIMEOUT_MS=15000

# Feature Flags (true/false)
VITE_ENABLE_UPI_REALTIME_POLLING=false
VITE_ENABLE_PERFORMANCE_MONITORING=false
VITE_ENABLE_MOBILE_SCANNER_CAMERA=true
